# ============================================
# MenagePro - Configuration des Environnements
# ============================================

# Copiez ce fichier vers .env et configurez vos valeurs
# ⚠️ NEVER commit .env to git - add it to .gitignore

# --------------------------------------------
# SUPABASE - Base de données et Auth
# --------------------------------------------
# Obtenez ces valeurs depuis: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# --------------------------------------------
# ADMIN - Configuration temporaire
# ⚠️ En production, migrer vers Supabase Auth avec RLS
# --------------------------------------------
ADMIN_EMAIL=admin@menagepro.com
ADMIN_PASSWORD=change-this-strong-password

# --------------------------------------------
# API - Endpoints personnalisés (optionnel)
# --------------------------------------------
API_ENDPOINT=https://api.menagepro.com

# --------------------------------------------
# NOTIFICATIONS - Configuration des services
# --------------------------------------------
# WhatsApp Business API (optionnel)
WHATSAPP_API_KEY=your-whatsapp-api-key

# Email service (SendGrid, Mailgun, etc.)
EMAIL_SERVICE_API_KEY=your-email-api-key

# SMS service (Twilio, etc.)
SMS_SERVICE_API_KEY=your-sms-api-key
